# Default: normalise all text files to LF in the repository
* text=auto eol=lf

# Explicitly LF for these file types
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Entrypoint must be LF — CRLF will break bash execution in Docker
entrypoint.sh text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.whl binary